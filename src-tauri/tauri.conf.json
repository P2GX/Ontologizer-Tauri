{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ontologizer",
  "version": "0.1.0",
  "identifier": "com.ontologizer.app",
  "build": {
    "frontendDist": "../dist/ontologizer/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "ng serve",
    "beforeBuildCommand": "ng build"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "ontologizer",
        "width": 1300,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}